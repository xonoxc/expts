{
	"$schema": "https://biomejs.dev",
	"formatter": {
		"enabled": true,
		"formatWithErrors": false,
		"indentStyle": "space",
		"indentWidth": 3,
		"lineWidth": 100
	},
	"javascript": {
		"formatter": {
			"semicolons": "asNeeded",
			"trailingCommas": "es5",
			"bracketSpacing": true,
			"arrowParentheses": "asNeeded"
		}
	},
	"json": {
		"formatter": {
			"trailingCommas": "none"
		}
	},
	"html": {
		"formatter": {
			"indentScriptAndStyle": true
		}
	}
}
